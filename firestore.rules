rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Colecciones PÚBLICAS (Solo lectura para todos)
    match /marketing_config/{document} { allow read: if true; }
    match /marketing_hero/{document} { allow read: if true; }
    match /marketing_features/{document} { allow read: if true; }
    match /marketing_testimonials/{document} { allow read: if true; }
    match /productos/{document} { allow read: if true; }
    match /categorias/{document} { allow read: if true; }
    match /galeria/{document} { allow read: if true; }
    match /inventario/{document} { allow read, update: if true; }

    // 2. Colecciones con LECTURA PRIVADA pero CREACIÓN/ACTUALIZACIÓN LIMITADA (Para clientes)
    match /pedidos/{document=**} { 
      allow create, update: if true; 
      allow read, delete: if request.auth != null; 
    }
    match /movimientos_inventario/{document=**} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // 3. Colecciones ESTRICTAMENTE PRIVADAS (Solo Administrador)
    match /inventario/{document=**} { allow write: if request.auth != null; }
    match /gastos/{document=**} { allow read, write: if request.auth != null; }
    match /movimientos_caja/{document=**} { allow read, write: if request.auth != null; }
    match /reportes/{document=**} { allow read, write: if request.auth != null; }
    match /recetas/{document=**} { allow read, write: if request.auth != null; }

    // Regla de respaldo para cualquier otra colección: requiere estar logeado
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
